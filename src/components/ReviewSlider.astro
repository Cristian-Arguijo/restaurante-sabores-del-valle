---
import { getCollection } from "astro:content";
const allReviews = await getCollection("reviews");
---

<div class="swiper w-full mt-8 rounded-2xl" style="background:rgba(200,146,42,0.08);border:1px solid rgba(200,146,42,0.2);">
	<div class="swiper-wrapper h-auto w-auto pt-10 pb-14">
		{
			allReviews.map((review) => (
				<div class="swiper-slide cursor-pointer select-none">
					<div class="px-6 lg:px-14">
						<div style="text-align:center;color:#C8922A;font-size:2rem;margin-bottom:0.75rem;">"</div>
						<blockquote class="border-none">
							<p style="text-align:center;font-family:'Lora',Georgia,serif;font-style:italic;font-size:1.1rem;line-height:1.8;color:#3D2010;">
								{review.data.review}
							</p>
							<footer style="text-align:center;margin-top:1.5rem;">
								<div style="display:inline-block;padding:0.25rem 1.25rem;background:#8B1A00;border-radius:999px;color:#FDF6E3;font-size:0.85rem;font-weight:600;letter-spacing:0.05em;">
									— {review.data.author}
								</div>
							</footer>
						</blockquote>
					</div>
				</div>
			))
		}
	</div>
	<div class="swiper-pagination" style="padding-bottom:0.5rem;"></div>
</div>

<script>
	import Swiper from "swiper";
	import { Pagination, Autoplay } from "swiper/modules";
	import "swiper/css";
	import "swiper/css/pagination";

	document.addEventListener("astro:page-load", () => {
		const swiper = document.querySelector(".swiper") as HTMLElement;
		if (!swiper) return;
		new Swiper(swiper, {
			modules: [Pagination, Autoplay],
			loop: true,
			slidesPerView: 1,
			spaceBetween: 32,
			autoplay: { delay: 3500 },
			pagination: { el: ".swiper-pagination" },
		});
	});
</script>