---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Hero from "~/components/Hero.astro";
import { Picture } from "astro:assets";
import Badge from "~/components/Badge.astro";
import Button from "~/components/Button.astro";
import ButtonCallUs from "~/components/ButtonCallUs.astro";
import Article from "~/components/Article.astro";

// Images
import CocinaHero from "~/assets/images/cocineros.jpeg";
import Local1 from "~/assets/images/local-1.jpg";
import Local2 from "~/assets/images/exterior.webp";
import Equipo from "~/assets/images/equipo.jpg";
import Equipo2 from "~/assets/images/cocineros-2.webp";
import Equipo3 from "~/assets/images/meseros.jpg";
---

<Layout>

	<!-- HERO -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none max-lg:order-1">
				<Badge title="sabores del valle" />

				<h1 class="font-black">
					Tradición hondureña que nace en cada cocina
				</h1>

				<p>
					En <strong>Sabores del Valle</strong> no solo servimos comida: compartimos cultura,
					tradición y el verdadero sabor de Honduras en cada plato.
				</p>

				<div class="mt-8 flex items-center gap-x-8">
					<Button url="/menu">Ver menú</Button>
					<ButtonCallUs />
				</div>
			</div>

			<div slot="hero-content-right">
				<Picture
					class:list={"mx-auto"}
					src={CocinaHero}
					height={600}
					formats={["avif", "webp"]}
					alt="Cocineros de Sabores del Valle"
				/>
			</div>
		</Hero>
	</Section>

	<!-- HISTORIA -->
	<Section class:list={'bg-white'}>
		<Article>
			<h2>Nuestra Historia</h2>

			<p>
				<strong>Sabores del Valle</strong> nació con una idea sencilla: llevar la auténtica comida hondureña
				a la mesa de cada familia, respetando las recetas tradicionales del país.
			</p>

			<p>
				Comenzamos como un pequeño emprendimiento familiar en el Valle de Honduras,
				cocinando baleadas, sopas y platos típicos con recetas heredadas de generación en generación.
			</p>

			<p>
				Con el tiempo, el amor de nuestros clientes nos permitió crecer,
				sin perder nunca lo más importante: el sabor casero y la identidad hondureña.
			</p>

			<blockquote>
				"Cada plato cuenta una historia, y cada historia sabe a Honduras."
			</blockquote>
		</Article>
	</Section>

	<!-- EQUIPO -->
	<Section class:list={"bg-white"}>
		<Article>
			<h2>Nuestro Equipo</h2>

			<p>
				Somos un equipo apasionado por la cocina tradicional hondureña.
				Chefs, cocineros y personal de servicio trabajan cada día para ofrecerte una experiencia auténtica.
			</p>

			<div class="grid md:grid-cols-3 gap-6 mt-8">

				<div class="text-center">
					<Picture src={Equipo} alt="Chef principal" class="rounded-xl" />
					<h3 class="font-bold mt-3">Cocina Tradicional</h3>
					<p>Especialistas en recetas hondureñas auténticas.</p>
				</div>

				<div class="text-center">
					<Picture src={Equipo2} alt="Equipo de cocina" class="rounded-xl" />
					<h3 class="font-bold mt-3">Equipo Familiar</h3>
					<p>Trabajamos con pasión como una gran familia.</p>
				</div>

				<div class="text-center">
					<Picture src={Equipo3} alt="Servicio al cliente" class="rounded-xl" />
					<h3 class="font-bold mt-3">Atención al Cliente</h3>
					<p>Siempre listos para atenderte con amabilidad.</p>
				</div>

			</div>
		</Article>
	</Section>

	<!-- LOCAL -->
	<Section class:list={"bg-white"}>
		<Article>
			<h2>Nuestro Local</h2>

			<p>
				Te invitamos a visitarnos y disfrutar de un ambiente cálido y familiar,
				donde cada detalle está pensado para que te sientas como en casa.
			</p>

			<div class="grid md:grid-cols-2 gap-6 mt-8">

				<div>
					<Picture src={Local1} alt="Interior del restaurante" class="rounded-xl" />
				</div>

				<div>
					<Picture src={Local2} alt="Área del restaurante" class="rounded-xl" />
				</div>

			</div>

			<p class="mt-6">
				En <strong>Sabores del Valle</strong> combinamos tradición, sabor y ambiente familiar
				para que cada visita sea una experiencia única.
			</p>

			<div class="mt-8">
				<Button url="/contacto">Visítanos</Button>
			</div>
		</Article>
	</Section>

</Layout>