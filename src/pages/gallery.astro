---
import Layout from "~/layouts/Layout.astro";

const galleryItems = [
  { emoji: "🍽️", label: "Sopa de Caracol", category: "platillos" },
  { emoji: "🌮", label: "Baleadas Especiales", category: "platillos" },
  { emoji: "🍗", label: "Pollo Chuco", category: "platillos" },
  { emoji: "🏡", label: "Salón Principal", category: "local" },
  { emoji: "🍮", label: "Tres Leches", category: "postres" },
  { emoji: "🌿", label: "Jardín Exterior", category: "local" },
  { emoji: "🫔", label: "Pastelitos de Carne", category: "platillos" },
  { emoji: "🎉", label: "Celebración de Cumpleaños", category: "eventos" },
  { emoji: "🍺", label: "Bebidas Artesanales", category: "bebidas" },
  { emoji: "👩‍🍳", label: "Nuestra Cocina", category: "local" },
  { emoji: "🍌", label: "Tajadas con Pollo", category: "platillos" },
  { emoji: "🥂", label: "Evento Corporativo", category: "eventos" },
];

const categories = ["todos", "platillos", "postres", "local", "eventos", "bebidas"];
---

<Layout title="Galería" description="Galería de fotos de Sabores del Valle — nuestros platillos, instalaciones y eventos especiales.">

  <!-- Hero -->
  <section style="background-color:#1A0A00;padding:4rem 0 3rem;">
    <div class="container" style="text-align:center;">
      <p style="color:#C8922A;font-size:0.8rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;font-family:'Lora',serif;margin-bottom:0.75rem;">
        Galería
      </p>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:900;color:#FDF6E3;margin-bottom:1rem;">
        Una Mirada a Nuestro Mundo
      </h1>
      <p style="color:#A89070;font-family:'Lora',serif;font-style:italic;font-size:1rem;">
        Platillos, instalaciones, eventos y momentos especiales
      </p>
    </div>
  </section>

  <!-- Filtros y galería con Alpine.js -->
  <section style="background-color:#FDF6E3;padding:4rem 0 6rem;">
    <div class="container" x-data="{ active: 'todos' }">

      <!-- Filtros -->
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;margin-bottom:3rem;">
        {categories.map(cat => (
          <button
            @click={`active = '${cat}'`}
            :class={`active === '${cat}' ? 'active-filter' : 'inactive-filter'`}
            style="padding:0.5rem 1.5rem;border-radius:999px;font-family:'Lora',serif;font-size:0.9rem;font-weight:600;text-transform:capitalize;transition:all 0.2s;cursor:pointer;border:2px solid #C8922A;"
            :style={`active === '${cat}' ? 'background:#8B1A00;color:#FDF6E3;border-color:#8B1A00;' : 'background:transparent;color:#8B1A00;'`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Grid de galería -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {galleryItems.map(item => (
          <div
            x-show={`active === 'todos' || active === '${item.category}'`}
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            style="aspect-ratio:1;border-radius:1rem;overflow:hidden;position:relative;border:1px solid #E8D5A0;cursor:pointer;"
            class="hover:-translate-y-1 hover:shadow-xl transition-transform duration-300"
          >
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#3D1A00,#1A0A00);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.75rem;">
              <span style="font-size:3.5rem;">{item.emoji}</span>
              <div style="position:absolute;bottom:0;left:0;right:0;padding:0.75rem;background:linear-gradient(to top,rgba(0,0,0,0.8),transparent);">
                <p style="color:#FDF6E3;font-size:0.8rem;font-weight:600;text-align:center;font-family:'Lora',serif;">
                  {item.label}
                </p>
                <p style="color:#C8922A;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;text-align:center;">
                  {item.category}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Nota de fotos reales -->
      <div style="margin-top:3rem;text-align:center;padding:1.5rem;background:#FFF8F0;border:1px dashed #C8922A;border-radius:1rem;">
        <p style="color:#6B4020;font-size:0.9rem;font-family:'Lora',serif;font-style:italic;">
          💡 <strong>Nota para el desarrollador:</strong> Reemplaza los íconos emoji con imágenes reales del restaurante. Usa el componente <code>&lt;Picture&gt;</code> de Astro para optimización automática.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Instagram -->
  <section style="background-color:#3D1A00;padding:4rem 0;">
    <div class="container" style="text-align:center;">
      <div style="font-size:2.5rem;margin-bottom:1rem;">📸</div>
      <h2 style="font-family:'Playfair Display',serif;color:#FDF6E3;font-size:2rem;font-weight:900;margin-bottom:0.75rem;">
        Síguenos en Instagram
      </h2>
      <p style="color:#A89070;margin-bottom:1.5rem;font-family:'Lora',serif;">
        Comparte tu visita con <strong style="color:#C8922A;">@saboresdelvalle</strong> y aparece en nuestra galería.
      </p>
      <a href="https://instagram.com/saboresdelvalle" class="button button-gold" target="_blank" rel="noopener">
        Ver en Instagram
      </a>
    </div>
  </section>

</Layout>