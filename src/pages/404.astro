---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
---

<Layout>
	<Section>
		<div class="min-h-full mx-auto w-full max-w-6xl flex items-center justify-center py-20">
			<div class="text-center">

				<p class="font-bold text-brand-red text-8xl">404</p>

				<h1 class="mt-8 text-4xl font-black text-balance lg:text-5xl">
					¡Ups! Esta página no existe
				</h1>

				<p class="mt-6 text-base text-balance text-gray-600">
					Parece que el enlace está incorrecto o la página fue movida.
					Pero aún puedes disfrutar lo mejor de <strong>Sabores del Valle</strong>.
				</p>

				<div class="mt-16">
					<a href="/" class="button button-green">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 20 20"
							fill="currentColor"
							class="size-4 inline-block -mt-0.5 mr-1"
						>
							<path
								fill-rule="evenodd"
								d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z"
								clip-rule="evenodd"
							></path>
						</svg>
						Volver al inicio
					</a>
				</div>

			</div>
		</div>
	</Section>
</Layout>