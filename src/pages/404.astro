---
import Layout from "~/layouts/Layout.astro";
---

<Layout title="Página no encontrada" description="Esta página no existe en Sabores del Valle.">
  <section style="background-color:#FDF6E3;padding:8rem 0;min-height:60vh;">
    <div class="container" style="text-align:center;">
      <p style="font-family:'Playfair Display',serif;font-weight:900;font-size:7rem;color:#8B1A00;line-height:1;">404</p>
      <h1 style="font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:900;color:#1A0A00;margin:1rem 0;">
        Página no encontrada
      </h1>
      <p style="color:#6B4020;font-family:'Lora',serif;font-size:1rem;max-width:400px;margin:0 auto 2.5rem;">
        Parece que esta página se perdió en el camino. No te preocupes, nuestro menú te espera.
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="button button-red">← Ir al Inicio</a>
        <a href="/menu" class="button button-outline" style="border-color:#8B1A00;color:#8B1A00;">Ver el Menú</a>
      </div>
    </div>
  </section>
</Layout>