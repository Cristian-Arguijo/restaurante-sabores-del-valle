---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Hero from "~/components/Hero.astro";
import { Picture } from "astro:assets";
import Badge from "~/components/Badge.astro";
import Button from "~/components/Button.astro";
import ButtonCallUs from "~/components/ButtonCallUs.astro";
import Grid from "~/components/Grid.astro";
import Heading from "~/components/Heading.astro";
import WideImage from "~/components/WideImage.astro";
import ReviewSlider from "~/components/ReviewSlider.astro";

// Images (puedes reemplazarlas luego por fotos reales de comida hondureña)
import HeroFood from "~/assets/images/pollo-hero.webp";
import BaleadasImg from "~/assets/images/baleadas.jpg";
import SopaCaracol from "~/assets/images/sopa-caracol.jpg";
import PolloChuco from "~/assets/images/pollo-chuco.jpg";
import DecorativeImage from "~/assets/images/cocinando.jpg";
import ReviewsImg from "~/assets/images/reseñas.jpg";
import DessertImg from "~/assets/images/tres-leches.png";
import PlatterImg from "~/assets/images/platillos.png";
---

<Layout title="Sabores del Valle" pageTitle="Sabores del Valle" description="Comida típica hondureña auténtica en Sabores del Valle. Baleadas, sopa de caracol, pollo chuco y más.">

	<!-- HERO PRINCIPAL -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none max-lg:order-1">
				<Badge title="sabores del valle" />
				<h1 class="font-black">Auténtica comida hondureña hecha con amor</h1>

				<p>
					Disfruta de los sabores tradicionales de Honduras: baleadas, sopa de caracol, pollo chuco,
					tajadas con pollo y mucho más. En Sabores del Valle te ofrecemos comida casera llena de tradición.
				</p>

				<span class="text-brand-green font-medium">✔ Servicio a domicilio disponible</span>

				<div class="mt-8 flex items-center gap-x-8">
					<Button url="/menu">Ver menú</Button>
					<ButtonCallUs />
				</div>
			</div>

			<div slot="hero-content-right">
				<Picture
					class:list={"mx-auto"}
					src={HeroFood}
					height={600}
					formats={["avif", "webp"]}
					alt="Comida hondureña"
					loading={"eager"}
					fetchpriority={"high"}
				/>
			</div>
		</Hero>
	</Section>

	<WideImage image={DecorativeImage} alt="Restaurante Sabores del Valle" class:list={"aspect-video lg:aspect-[16/6]"} />

	<!-- DESTACADOS -->
	<Section class:list={"bg-white"}>
		<Heading>
			<h2 slot="heading-title" class="font-black text-brand-green h2">Nuestros favoritos</h2>
			<p slot="heading-content">
				Platos tradicionales hondureños más pedidos por nuestros clientes.
			</p>
		</Heading>

		<Grid>
			<div slot="grid-content-1">
				<div class="flex flex-col items-center text-center gap-1">
					<Picture src={BaleadasImg} alt="Baleadas hondureñas" />
					<h3 class="h4 font-black">Baleadas</h3>
					<p>Baleadas sencillas, especiales y con pollo. El ícono de Honduras en cada bocado.</p>
				</div>
			</div>
			<div slot="grid-content-2"></div>
			<div slot="grid-content-2">
				<div class="flex flex-col items-center text-center gap-1">
					<Picture src={SopaCaracol} alt="Sopa de caracol" />
					<h3 class="h4 font-black">Sopa de Caracol</h3>
					<p>El sabor caribeño más famoso de Honduras con leche de coco y especias.</p>
				</div>
			</div>
			<div slot="grid-content-2"></div>
			<div slot="grid-content-3">
				<div class="flex flex-col items-center text-center gap-1">
					<Picture src={PolloChuco} alt="Pollo chuco" />
					<h3 class="h4 font-black">Pollo Chuco</h3>
					<p>Pollo frito estilo hondureño con tajadas, repollo y salsa roja.</p>
				</div>
			</div>
		</Grid>
	</Section>

	<!-- PLATO PRINCIPAL -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose lg:order-2">
				<h1 class="font-black">Sabor típico de Honduras</h1>

				<p>
					Nuestros platos están inspirados en la cocina tradicional hondureña, preparados con ingredientes frescos
					y recetas auténticas del Valle.
				</p>

				<div class="mt-8">
					<Button url="/menu">
						Ver menú completo
					</Button>
				</div>
			</div>

			<div slot="hero-content-right">
				<Picture src={PlatterImg} height={600} alt="Plato típico hondureño" />
			</div>
		</Hero>
	</Section>

	<!-- PLATO DE LA SEMANA -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none">
				<Badge color="red" title="plato de la semana" />
				<h2 class="font-black h2 !my-4">Sopa de Caracol</h2>

				<p>
					Disfruta nuestra especialidad de la semana: la tradicional sopa de caracol con leche de coco,
					yuca, plátano y especias caribeñas.
				</p>

				<div class="mt-8">
					<Button color="red" url="/book">Reservar ahora</Button>
				</div>
			</div>

			<div slot="hero-content-right">
				<Picture src={SopaCaracol} height={600} alt="Sopa de caracol" />
			</div>
		</Hero>
	</Section>

	<!-- RESEÑAS -->
	<Section class:list={"bg-brand-red/20 relative"}>
		<div class="py-16">
			<Hero>
				<div slot="hero-content-left" class="prose max-w-none order-2">
					<div class="text-center not-prose">
						<Badge color="white" title="reseñas" />
					</div>

					<h2 class="font-black text-center h4 mt-0 mb-4">
						Lo que dicen nuestros clientes
					</h2>

					<p class="text-center">
						Experiencias reales de personas que disfrutan nuestra comida hondureña.
					</p>

					<ReviewSlider />
				</div>

				<div slot="hero-content-right">
					<Picture src={ReviewsImg} alt="Clientes felices" />
				</div>
			</Hero>
		</div>
	</Section>

	<!-- POSTRES -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose">
				<Badge title="postres" />
				<h2 class="font-black h2 !my-4">Dulces tradicionales</h2>

				<p>
					Endulza tu experiencia con tres leches, arroz con leche, buñuelos y más postres típicos hondureños.
				</p>

				<div class="mt-8">
					<Button url="/menu">Ver postres</Button>
				</div>
			</div>

			<div slot="hero-content-right">
				<Picture src={DessertImg} height={600} alt="Postres hondureños" />
			</div>
		</Hero>
	</Section>

	<!-- CONTACTO -->
	<Section class:list={"bg-white"}>
		<Hero>
			<div slot="hero-content-left" class="prose">
				<Badge color="red" title="contacto" />
				<h2 class="font-black text-brand-red h2 !my-4">Visítanos en Sabores del Valle</h2>

				<p>
					Estamos ubicados en Honduras. Ven y disfruta comida típica hecha como en casa.
				</p>

				<span class="text-brand-red font-medium">
					✔ También tenemos servicio para llevar
				</span>

				<div class="mt-8">
					<Button color="red" url="/contacto">Contáctanos</Button>
				</div>
			</div>

			<div slot="hero-content-right">
				<img src={"src/assets/images/viva-honduras.png"} height={600} alt="Restaurante" />
			</div>
		</Hero>
	</Section>

</Layout>